<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>@ViewData["Title"] - CtrlZMyBody Admin</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
<div id="admin-shell">
    <aside id="sidebar">
        <div class="brand">CtrlZMyBody Admin</div>
        <nav>
            @{
                var action = ViewContext.RouteData.Values["action"]?.ToString();
            }
            <a href="/admin/users" class="@(action == "Users" ? "active" : "")">Користувачі</a>
            <a href="/admin/exercises" class="@(action == "Exercises" ? "active" : "")">Вправи</a>
            <a href="/admin/categories" class="@(action == "Categories" ? "active" : "")">Категорії</a>
            <a href="/admin/injuries" class="@(action == "InjuryTypes" ? "active" : "")">Типи травм</a>
            <a href="/admin/difficulties" class="@(action == "DifficultyLevels" ? "active" : "")">Рівні складності</a>
            <a href="/admin/plans" class="@(action == "WorkoutPlans" ? "active" : "")">Плани тренувань</a>
            <a href="/admin/challenges" class="@(action == "Challenges" ? "active" : "")">Челенджі</a>
        </nav>
        <a href="/admin/logout" class="logout">Вийти</a>
    </aside>

    <div id="main">
        <header id="topbar">
            <h1>@ViewData["Title"]</h1>
            <span class="user-badge">@Context.Session.GetString("AdminName")</span>
        </header>

        <main id="content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-error">@TempData["Error"]</div>
            }
            @RenderBody()
        </main>
    </div>
</div>
</body>
</html>

