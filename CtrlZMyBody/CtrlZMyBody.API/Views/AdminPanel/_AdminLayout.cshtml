    <!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>@ViewData["Title"] — CtrlZMyBody Admin</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: Arial, sans-serif; font-size: 14px; background: #f0f2f5; display: flex; height: 100vh; overflow: hidden; }

#sidebar { width: 210px; min-width: 210px; background: #2c3e50; color: #fff; display: flex; flex-direction: column; }
#sidebar .brand { padding: 15px 14px; font-size: 13px; font-weight: bold; background: #1a252f; border-bottom: 1px solid #3d5166; letter-spacing: .3px; }
#sidebar nav a {
    display: block; padding: 11px 14px; color: #b2bec3; text-decoration: none;
    border-left: 3px solid transparent; font-size: 13px; transition: background .15s;
}
#sidebar nav a:hover { background: #34495e; color: #fff; }
#sidebar nav a.active { background: #34495e; color: #fff; border-left-color: #3498db; }
#sidebar .logout {
    margin-top: auto; display: block; padding: 12px 14px;
    color: #e74c3c; text-decoration: none; font-size: 13px; border-top: 1px solid #3d5166;
}
#sidebar .logout:hover { background: #34495e; }

#main { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }
#topbar {
    background: #fff; padding: 11px 22px; border-bottom: 1px solid #ddd;
    display: flex; align-items: center; justify-content: space-between;
}
#topbar h1 { font-size: 17px; color: #2c3e50; font-weight: bold; }
#topbar .user-badge { font-size: 12px; color: #636e72; background: #f1f2f6; padding: 4px 10px; border-radius: 12px; }
#content { flex: 1; overflow-y: auto; padding: 20px 22px; }

.alert { padding: 10px 14px; border-radius: 4px; margin-bottom: 16px; font-size: 13px; }
.alert-success { background: #d5f5e3; color: #1e8449; border: 1px solid #a9dfbf; }
.alert-error   { background: #fdecea; color: #c0392b; border: 1px solid #f5b7b1; }

.page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
.page-header h2 { font-size: 16px; color: #2c3e50; }
.btn-add {
    background: #27ae60; color: #fff; border: none; padding: 7px 16px;
    border-radius: 3px; cursor: pointer; font-size: 13px; text-decoration: none; display: inline-block;
}
.btn-add:hover { background: #219a52; }

.grid2 { display: grid; grid-template-columns: 1fr 320px; gap: 18px; align-items: start; }

.table-wrap { background: #fff; border-radius: 4px; box-shadow: 0 1px 4px rgba(0,0,0,.08); overflow: hidden; }
table { width: 100%; border-collapse: collapse; }
th { background: #f5f6fa; padding: 9px 12px; text-align: left; font-size: 12px; color: #636e72; border-bottom: 2px solid #dfe6e9; white-space: nowrap; }
td { padding: 8px 12px; border-bottom: 1px solid #f1f2f6; font-size: 13px; vertical-align: middle; }
tr:last-child td { border-bottom: none; }
tr:hover td { background: #fafbfc; }
td.actions { white-space: nowrap; }

.btn-edit {
    background: #3498db; color: #fff; border: none; padding: 4px 10px;
    border-radius: 3px; cursor: pointer; font-size: 12px; text-decoration: none; display: inline-block; margin-right: 3px;
}
.btn-edit:hover { background: #2980b9; }
.btn-del { background: #e74c3c; color: #fff; border: none; padding: 4px 10px; border-radius: 3px; cursor: pointer; font-size: 12px; }
.btn-del:hover { background: #c0392b; }

.badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: bold; }
.bg { background: #d5f5e3; color: #1e8449; }
.br { background: #fdecea; color: #c0392b; }
.bb { background: #d6eaf8; color: #2471a3; }
.bo { background: #fef9e7; color: #d68910; }

.form-panel { background: #fff; border-radius: 4px; box-shadow: 0 1px 4px rgba(0,0,0,.08); padding: 18px; }
.form-panel h3 { font-size: 14px; color: #2c3e50; margin-bottom: 14px; padding-bottom: 10px; border-bottom: 1px solid #f1f2f6; }
.form-group { margin-bottom: 11px; }
.form-group label { display: block; font-size: 12px; color: #636e72; margin-bottom: 4px; }
.form-group input,
.form-group select,
.form-group textarea {
    width: 100%; padding: 7px 9px; border: 1px solid #dfe6e9;
    border-radius: 3px; font-size: 13px; color: #2d3436;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus { outline: none; border-color: #3498db; }
.form-group textarea { height: 68px; resize: vertical; }
.form-group.check { display: flex; align-items: center; gap: 7px; margin-top: 6px; }
.form-group.check label { margin: 0; cursor: pointer; }
.form-group.check input[type=checkbox] { width: auto; cursor: pointer; }
.btn-save {
    width: 100%; padding: 9px; background: #27ae60; color: #fff;
    border: none; border-radius: 3px; cursor: pointer; font-size: 13px; margin-top: 6px;
}
.btn-save:hover { background: #219a52; }
.cancel-link { display: block; text-align: center; margin-top: 8px; font-size: 12px; color: #999; text-decoration: none; }
.cancel-link:hover { color: #636e72; }
</style>
</head>
<body>

<div id="sidebar">
  <div class="brand">⚙ CtrlZMyBody Admin</div>
  <nav>
    @{
        var action = ViewContext.RouteData.Values["action"]?.ToString();
    }
    <a href="/admin/users"       class="@(action == "Users"            ? "active" : "")">👤 Користувачі</a>
    <a href="/admin/exercises"   class="@(action == "Exercises"        ? "active" : "")">🏋️ Вправи</a>
    <a href="/admin/categories"  class="@(action == "Categories"       ? "active" : "")">📁 Категорії</a>
    <a href="/admin/injuries"    class="@(action == "InjuryTypes"      ? "active" : "")">🦴 Типи травм</a>
    <a href="/admin/difficulties" class="@(action == "DifficultyLevels" ? "active" : "")">📊 Рівні склад.</a>
    <a href="/admin/plans"       class="@(action == "WorkoutPlans"     ? "active" : "")">📋 Плани</a>
    <a href="/admin/challenges"  class="@(action == "Challenges"       ? "active" : "")">🏆 Челенджі</a>
  </nav>
  <a href="/admin/logout" class="logout">🚪 Вийти</a>
</div>

<div id="main">
  <div id="topbar">
    <h1>@ViewData["Title"]</h1>
    <span class="user-badge">@Context.Session.GetString("AdminName")</span>
  </div>
  <div id="content">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">✔ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error">✘ @TempData["Error"]</div>
    }
    @RenderBody()
  </div>
</div>

</body>
</html>


