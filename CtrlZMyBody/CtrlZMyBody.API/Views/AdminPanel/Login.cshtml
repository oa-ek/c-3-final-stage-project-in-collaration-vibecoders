@{
    ViewData["Title"] = "Вхід";
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<title>Admin Login — CtrlZMyBody</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: Arial, sans-serif; background: #2c3e50; display: flex; align-items: center; justify-content: center; height: 100vh; }
.box { background: #fff; padding: 34px 32px; border-radius: 4px; width: 320px; box-shadow: 0 4px 20px rgba(0,0,0,.3); }
.box h2 { margin-bottom: 6px; color: #2c3e50; font-size: 18px; }
.box p { color: #888; font-size: 12px; margin-bottom: 22px; }
.box label { display: block; font-size: 12px; color: #636e72; margin-bottom: 4px; }
.box input {
    width: 100%; padding: 9px 10px; margin-bottom: 14px;
    border: 1px solid #ddd; border-radius: 3px; font-size: 14px;
}
.box input:focus { outline: none; border-color: #3498db; }
.box button {
    width: 100%; padding: 10px; background: #3498db; color: #fff;
    border: none; border-radius: 3px; cursor: pointer; font-size: 14px;
}
.box button:hover { background: #2980b9; }
.error { color: #e74c3c; font-size: 13px; margin-top: 10px; }
</style>
</head>
<body>
<div class="box">
  <h2>CtrlZMyBody</h2>
  <p>Панель адміністратора</p>
  <form method="post" action="/admin/login">
    <label>Email</label>
    <input type="email" name="email" placeholder="admin@admin.com" required autofocus>
    <label>Пароль</label>
    <input type="password" name="password" placeholder="••••••••" required>
    <button type="submit">Увійти</button>
  </form>
  @if (ViewBag.Error != null)
  {
      <div class="error">✘ @ViewBag.Error</div>
  }
</div>
</body>
</html>

